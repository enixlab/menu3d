{
  "expo": {
    "name": "Menu3D",
    "slug": "menu3d",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "menu3d",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.enixlab.menu3d",
      "infoPlist": {
        "NSCameraUsageDescription": "Menu3D utilise la caméra pour scanner vos plats en 3D",
        "NSPhotoLibraryUsageDescription": "Pour importer des logos et bannières",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.enixlab.menu3d",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Menu3D a besoin de la caméra pour scanner les plats en 3D"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pour importer logos et bannières"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5e5f08d4-ce19-4f0d-b042-92aec2b12bce"
      }
    },
    "owner": "enix-lab"
  }
}
